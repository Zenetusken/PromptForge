# Runtime data — nothing in this directory should be committed.
# The root .gitignore already has `data/*` but this file serves
# as defense-in-depth and documents the directory's contents.

# Database
*.db
*.sqlite3

# Secrets
.app_secrets
.api_credentials

# User state
preferences.json
mcp_session.json

# Traces and logs
traces/
*.log

# Caches
*.pkl

# Process management
pids/
